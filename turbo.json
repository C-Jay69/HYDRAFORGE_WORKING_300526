{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "env": [
        "BETTER_AUTH_URL",
        "DATABASE_URL",
        "DATABASE_AUTH_TOKEN",
        "BETTER_AUTH_SECRET",
        "OPENROUTER_API_KEY",
        "WEBSITE_URL",
        "AUTUMN_SECRET_KEY",
        "FRONTEND_URL",
        "AUTUMN_API_KEY",
        "AUTUMN_PROJECT_ID"
      ]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
