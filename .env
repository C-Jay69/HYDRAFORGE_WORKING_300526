# Database
# For local development, use "file:local.db".
# For production, use a Turso/libSQL URL (e.g., "libsql://your-db.turso.io")
DATABASE_URL="file:local.db"

# Authentication (Better Auth)
# Generate a random string for the secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET="your_better_auth_secret"
# The public URL of your app (e.g., "http://localhost:3000")
BETTER_AUTH_URL="http://localhost:3000"

# AI / LLM (OpenRouter)
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY="your_openrouter_api_key"

# Billing & Quota (Autumn-js)
# These are required for the Autumn quota system used in the analyses route
AUTUMN_API_KEY="your_autumn_api_key"
AUTUMN_PROJECT_ID="your_autumn_project_id"
