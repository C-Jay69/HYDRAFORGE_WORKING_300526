# Database (Turso/libSQL)
# For local dev: DATABASE_URL="file:local.db" (no token needed)
# For production: use your Turso DB URL + token
DATABASE_URL="libsql://your-db.aws-us-east-2.turso.io"
DATABASE_AUTH_TOKEN="your_turso_auth_token"

# Authentication (Better Auth)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your_better_auth_secret"
# Must match your deployment URL exactly
BETTER_AUTH_URL="https://your-domain.com"

# Frontend URL — used for CORS origin locking + Better Auth trustedOrigins
# Must match your production domain
FRONTEND_URL="https://your-domain.com"

# AI / LLM (OpenRouter)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# Billing & Quota (Autumn-js)
# Get from: https://useautumn.com
AUTUMN_API_KEY="am_sk_live_..."
AUTUMN_PROJECT_ID="YOUR_PROJECT_ID"
