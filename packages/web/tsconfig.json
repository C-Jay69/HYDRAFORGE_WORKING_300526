{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "outDir": "dist"
  },
  "include": ["src"]
}
