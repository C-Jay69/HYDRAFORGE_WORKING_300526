/** Error body returned by backend routes */
type BackendErrorBody = {
    message: string;
    code: string;
    statusCode: number;
    details?: unknown;
};
/** Result returned by route handlers */
type BackendResult<T = unknown> = {
    statusCode: number;
    body: T | BackendErrorBody | null;
};

export type { BackendErrorBody, BackendResult };
